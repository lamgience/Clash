# ------------------------------------------------------------------------------
# 8. 分流规则 (精准匹配新组名，绝不手抖)
# ------------------------------------------------------------------------------
rules:
  - DST-PORT,123,DIRECT
  - RULE-SET,LocalAreaNetwork,🌐 全局直连
  - RULE-SET,private,DIRECT
  - RULE-SET,UnBan,🌐 全局直连
  - RULE-SET,BanAD,🛑 广告拦截
