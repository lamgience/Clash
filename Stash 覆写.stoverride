    proxies: [DIRECT, 🎯 节点切换, 🚀 自动优选]

  - name: 🛑 广告拦截
    type: select
    icon: "https://testingcf.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/AdBlack.png"
    proxies: [REJECT, DIRECT]

  - name: 🧹 应用净化
    type: select
    icon: "https://testingcf.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Hijacking.png"
    proxies: [REJECT, DIRECT]

  - name: 🐠 漏网之鱼
    type: select
    icon: "https://testingcf.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Final.png"
    proxies: [🚀 自动优选, 🎯 节点切换, 🖐️ 手动指定, 🇭🇰 香港地区, 🇹🇼 台湾地区, 🇺🇸 美国地区, 🇯🇵 日本地区, 🇸🇬 新加坡地区, 🇬🇧 英国地区, 🇰🇷 韩国地区, 🇦🇺 澳洲地区, 🇷🇺 俄国地区, 🌍 其他地区, DIRECT]

  - name: 🇭🇰 香港地区
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 50
    icon: https://testingcf.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Hong_Kong.png
    filter: "(?i)香港|Hong Kong|HK|🇭🇰|HongKong|HGC|WTT|HKBN|PCCW"
    include-all: true
    exclude-filter: "(?i)Traffic|Expire|Premium|频道|订阅|ISP|流量|到期|重置|请勿|剩余|套餐|跳转|官网|运营|更新"

  - name: 🇹🇼 台湾地区
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 50
    icon: https://testingcf.jsdelivr.net/gh/Koolson/Qure@master/IconSet/Color/Taiwan.png
    filter: "(?i)台湾|臺灣|Taiwan|TW|🇹🇼|TaiWan|Hinet|TFN"
    include-all: true
    exclude-filter: "(?i)Traffic|Expire|Premium|频道|订阅|ISP|流量|到期|重置|请勿|剩余|套餐|跳转|官网|运营|更新"

